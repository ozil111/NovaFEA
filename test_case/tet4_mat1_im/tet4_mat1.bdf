$$------------------------------------------------------------------------------$
  ANALYSIS = STATICS
$
$HMNAME LOADSTEP               1"loadstep1"
SUBCASE       1
  SUBTITLE  = loadstep1
  LABEL= loadstep1
  SPC =        1
  LOAD =        5
  ANALYSIS = STATICS
  GPFORCE = ALL
  OLOAD = ALL
  STRAIN = ALL
  STRESS = ALL
  Displacement=ALL
$$------------------------------------------------------------------------------$
$$                      Bulk Data Cards                                         $
$$------------------------------------------------------------------------------$
BEGIN BULK
PARAM,POST,-2      
$$
$$  GRID Data
$$
GRID           1             0.0     0.0     0.0
GRID           2             1.0     0.0     0.0
GRID           3             0.0     1.0     0.0
GRID           4             0.0     0.0     1.0
$$
$$------------------------------------------------------------------------------$
$$             Group Definitions                                                $
$$------------------------------------------------------------------------------$
$$
$$  CTETRA elements 4-noded
$$
$HMCOMP ID                     1
CTETRA         1       1       4       1       3       2
$
SET1           2       1       2       3
$HMSET        2        1 "set2" 18
$HMSETTYPE         2 "regular" 18
$$
